# Copy to .env and fill in real values
N8N_HOST=https://your-n8n-instance.com
N8N_API_KEY=your_n8n_api_key
ZOHO_CID=your_zoho_client_id
ZOHO_CS=your_zoho_client_secret
ZOHO_RT=your_zoho_refresh_token
GALLABOX_KEY=your_gallabox_api_key
GALLABOX_SECRET=your_gallabox_api_secret
GALLABOX_CHANNEL=your_gallabox_channel_id
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key
OPENROUTER_KEY=your_openrouter_api_key
